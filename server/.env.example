# NÃO coloque sua chave aqui! Use o arquivo .env (ele está no .gitignore).
# Copie: cp .env.example .env   e edite o .env com sua chave real.
#
# OpenRouter API Key (obrigatório para /api/generate-build)
# Obtenha em: https://openrouter.ai/keys
# Documentação: https://openrouter.ai/docs/quickstart
OPENROUTER_API_KEY=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

# Opcional: URL do seu site (para ranking no OpenRouter)
# Ex: https://seu-site.vercel.app ou https://github.com/seu-usuario/poe_easy_build_ai
OPENROUTER_SITE_URL=https://openrouter.ai/docs/quickstart

# Opcional: modelo OpenRouter para CHAT (gerar texto). Use um de chat, não de embedding.
# Ex.: z-ai/glm-4.5-air:free. Lista: https://openrouter.ai/collections/free-models
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
